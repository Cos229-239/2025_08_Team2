{
    "name": "Raven Gaming Backend",
    "dockerComposeFile": "docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/backend",
    "customizations": {
        "vscode": {
            "extensions": [
                "jakebecker.elixir-ls",
                "phoenixframework.phoenix",
                "bradlc.vscode-tailwindcss",
                "phoenixframework.phoenix",
                "msaraiva.surface"
            ],
            "settings": {
                "elixirLS.dialyzerEnabled": true,
                "editor.formatOnSave": true,
                "terminal.integrated.defaultProfile.linux": "zsh",
                "terminal.integrated.profiles.linux": {
                    "zsh": {
                        "path": "/usr/bin/zsh",
                        "args": [],
                        "icon": "terminal"
                    }
                }
            }
        }
    },
    "forwardPorts": [
        4000
    ],
    "postCreateCommand": "mix local.hex --force && mix local.rebar --force && mix archive.install hex phx_new 1.7.21 --force",
    "postStartCommand": "echo 'Raven Gaming Backend container is ready!'"
}